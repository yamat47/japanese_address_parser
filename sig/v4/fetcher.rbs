# Interim signature for the v4.0.0 config & data-access layer (M3).
# The full RBS overhaul happens in M9.

module JapaneseAddressParser
  module V4
    module Fetcher
      class Response
        attr_reader body: String
        attr_reader ok: bool

        def self.new: (body: String, ok: bool) -> Response
                    | (String body, bool ok) -> Response

        def json: () -> untyped
        def text: () -> String
      end

      USER_AGENT: String

      def self.fetch: (String input, ?offset: Integer?, ?length: Integer?) -> Response
      def self.http_request: (String url, Integer? offset, Integer? length) -> Response
      def self.read_file: (String path, Integer? offset, Integer? length) -> Response
    end
  end
end
